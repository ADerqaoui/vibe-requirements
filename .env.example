# Copy to .env and fill in. .env is gitignored — never commit it.
# API keys live ONLY here, never in the database or backups.

# --- Cloud LLM API keys (blank = that provider is disabled) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# --- Ollama (local) ---
OLLAMA_HOST=http://localhost:11434

# --- Database ---
DATABASE_URL=sqlite:///./vibe-requirements.db

# --- App ---
APP_PORT=8000
LOG_LEVEL=INFO
